package Day_10;

public class String_Reverse {
    public static void main(String[] args){
        String str="hello";
        char [] arr=str.toCharArray();
        int Start=0,End=arr.length-1;
        while(Start<=End){
            char temp=arr[Start];
            arr[Start]=arr[End];
            arr[End]=temp;
            Start++;
            End--;
        }
        String s=new String(arr);
        System.out.println(s);
    }
}
