import java.util.Scanner;
public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        System.out.println("enter a number:");
        int num=sc.nextInt();
        int largest_value=0;
        while(num!=0){
            int pop=num%10;
            if(pop>largest_value){
                largest_value=pop;
            }
            num=num/10;
        }
        System.out.println(largest_value);
    }
}
