import java.util.Scanner;
public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        System.out.println("enter a number:");
        int num=sc.nextInt();
        int org=num;
        int sum=0;
        while(num!=0){
            int pop=num%10;
            sum+=pop*pop*pop;
            num=num/10;
        }
        if(sum==org){
            System.out.println("amstrong number");
        }
        else{
            System.out.println("not amstrong number");
        }
    }
}
